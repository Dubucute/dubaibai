{
  "name": "dubu-ai",
  "version": "2.0.0",
  "description": "Dubu AI — Autonomous Agent Platform powered by NVIDIA NIM",
  "engines": {
    "node": ">=19"
  },
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern .freebuff",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern .freebuff --fix",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "multer": "^2.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5"
  }
}
